{
  "name": "Basic Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "features": {
    "ghcr.io/Evit15/devcontainer-features/adb-fastboot:1":{
      "installTools": true,
      "version": "3.10"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy"
      ]
    }
  },
  "postCreateCommand": ".devcontainer/postCreate.sh"
}
